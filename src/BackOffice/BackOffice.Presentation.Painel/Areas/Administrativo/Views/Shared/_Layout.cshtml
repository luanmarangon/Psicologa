@{
    dynamic sideBarItens = new List<dynamic>();

    var cadastros = new { Titulo = "Gerenciador", IconeClass = "fas fa-folder", Filhos = new List<dynamic>() };


    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarPessoas))
    {
        cadastros.Filhos.Add(new { Titulo = "Pessoas", HRef = "Administrativo/Pessoa", IconeClass = "fas fa-user-friends", Tag = ""});
    }

    if(permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarServicos))
    {
        cadastros.Filhos.Add(new { Titulo = "Serviços", HRef = "Administrativo/Servico", IconeClass = "fas fa-brain", Tag = "" });
    }

    if(permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarConvenios))
    {
        cadastros.Filhos.Add(new { Titulo = "Convênios", HRef = "Administrativo/Convenio", IconeClass = "fas fa-handshake", Tag = "" });
    }


    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarUsuarios))
    {
        cadastros.Filhos.Add(new { Titulo = "Usuários", HRef = "Administrativo/Usuario", IconeClass = "fas fa-users", Tag = "" });
    }


    if (cadastros.Filhos.Count > 0)
    {
        sideBarItens.Add(cadastros);
    }


    var blog = new { Titulo = "Blog", IconeClass = "fas fa-newspaper", Filhos = new List<dynamic>() };

    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.AcessarConteudoBlog))
    {
        blog.Filhos.Add(new { Titulo = "Blog's", HRef = "Administrativo/BlogPost", IconeClass = "fas fa-book-open", Tag = "" });
        blog.Filhos.Add(new { Titulo = "Novo Blog", HRef = "Administrativo/BlogPost/NovoPost", IconeClass = "fas fa-edit", Tag = "" });
    }

    if (blog.Filhos.Count > 0)
    {
        sideBarItens.Add(blog);
    }

    var leads = new { Titulo = "Leads", IconeClass = "fas fa-address-book", Filhos = new List<dynamic>() };

    // var leads = new { Titulo = "Leads", IconClass = "fas fa-address-book", Filhos = new List<dynamic>() };

    if(permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarLeads))
    {
        leads.Filhos.Add(new { Titulo = "Gerenciar Leads", HRef = "Administrativo/Leads", IconeClass = "fas fa-address-book", Tag = "" });
    }

    if(leads.Filhos.Count > 0)
    {
        sideBarItens.Add(leads);
    }

    var pacientes = new { Titulo = "Pacientes", IconeClass = "fas fa-clinic-medical", Filhos = new List<dynamic>() };

    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarPacientes))
    {
        pacientes.Filhos.Add(new { Titulo = "Pacientes", HRef = "Administrativo/Paciente", IconeClass = "fas fa-procedures", Tag = "" });
        // pacientes.Filhos.Add(new { Titulo = "Prontuário", HRef = "Administrativo/Paciente", IconeClass = "fas fa-notes-medical", Tag = "" });
    }

    if (pacientes.Filhos.Count > 0)
    {
        sideBarItens.Add(pacientes);
    }


    var agendamentos = new { Titulo = "Agendamentos", IconeClass = "fas fa-calendar-alt", Filhos = new List<dynamic>() };

    // var leads = new { Titulo = "Leads", IconClass = "fas fa-address-book", Filhos = new List<dynamic>() };

    if(permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarAgendamentos))
    {
        agendamentos.Filhos.Add(new { Titulo = "Gerenciar Agendamentos", HRef = "Administrativo/Agendamento", IconeClass = "fas fa-calendar-alt", Tag = "" });
    }

    if(agendamentos.Filhos.Count > 0)
    {
        sideBarItens.Add(agendamentos);
    }

    var configs = new { Titulo = "Configurações", IconeClass = "fas fa-cog", Filhos = new List<dynamic>() };

    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarPermissoes))
    {
        configs.Filhos.Add(new { Titulo = "Permissões de Usuário", HRef = "Administrativo/PerfilUsuario", IconeClass = "fas fa-users-cog", Tag = "" });
    }

    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarConfiguracoes))
    {            
        configs.Filhos.Add(new { Titulo = "Configurações", HRef = "Administrativo/Configuracao", IconeClass = "fas fa-cogs", Tag = "" });
    }


    if (configs.Filhos.Count > 0)
    {
        sideBarItens.Add(configs);
    }

    var documentos = new { Titulo = "Documentos", IconeClass = "fas fa-file-alt", Filhos = new List<dynamic>() };
    if(permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarDocumentos))
    {
        documentos.Filhos.Add(new { Titulo = "Gerenciar Documentos", HRef = "Administrativo/Documentos", IconeClass = "fas fa-file-alt", Tag = "" });
    }

    if(documentos.Filhos.Count > 0)
    {
        sideBarItens.Add(documentos);
    }

    var logs = new { Titulo = "Logs", IconeClass = "fas fa-clipboard-list", Filhos = new List<dynamic>() };

    if(permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.GerenciarLogsAplicacao))
    {
        logs.Filhos.Add(new { Titulo = "Logs de Aplicação", HRef = "Administrativo/LogAplicacao", IconeClass = "fas fa-clipboard-list", Tag = "" });
    }

    if(logs.Filhos.Count > 0)
    {
        sideBarItens.Add(logs);
    }

    var relatorios = new { Titulo = "Relatórios", IconeClass = "fas fa-poll", Filhos = new List<dynamic>() };

    if (permissoes.Contains(PerfilUsuarioViewModel.TpPermissao.Relatorios))
    {
        // relatorios.Filhos.Add(new { Titulo = "Registros de Acessos", HRef = "Administrativo/EspacoPaginaRegistroAcesso", IconeClass = "fas fa-file", Tag = "" });
    }
   
  
    if (relatorios.Filhos.Count > 0)
    {
        sideBarItens.Add(relatorios);
    }


}

