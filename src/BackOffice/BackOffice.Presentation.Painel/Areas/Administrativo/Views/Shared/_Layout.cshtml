@inject IAppSettings appSetting
@inject UsuarioAutenticado ua;

@{
    var permissoes = ua.Permissoes;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=2.0">
    <meta http-equiv="x-ua-compatible" content="ie=edge">

    <title>@(ViewData["Title"] != null && ViewData["Title"].ToString() != "" ? ViewData["Title"].ToString().Trim() + " - " : "")@appSetting.Nome</title>

    <link rel="icon" type="image/png" href="~/img/favicon.png">
    <link rel="stylesheet" href="~/template/AdminLTE/plugins/fontawesome-free/css/all.min.css">
    <link href="~/template/AdminLTE/plugins/select2/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/template/AdminLTE/dist/css/adminlte.min.css">
    <link href="~/template/AdminLTE/custom.css?cache=@appSetting.Version" rel="stylesheet" />
    <link href="~/css/site.css?cache=@appSetting.Version" rel="stylesheet" />
    <link href="~/css/loading.css?cache=@appSetting.Version" rel="stylesheet" />

    @RenderSection("Styles", required: false)
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js" crossorigin="anonymous"></script>

    @* //Deve ser importado no início *@
    <script>
            const BASE_URL = "@appSetting.BaseURL";
    </script>

    <script src="~/js/site.js?cache=@appSetting.Version"></script>
