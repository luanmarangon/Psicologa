                            <br />
                            Presidente Prudente - SP, Brasil
                        </p>
                        <p><i class="fa fa-phone-alt mr-2"></i>0800 770 2014</p>
                        <p><i class="fa fa-envelope mr-2"></i>egestora@egestora.com.br</p>

                        <div class="d-flex justify-content-start mt-4">
                            <a class="text-white mr-4" href="https://wa.me/551832262200" target="_blank"><i class="fab fa-2x fa-whatsapp"></i></a>
                            <a class="text-white mr-4" href="https://www.fb.com/egestora" target="_blank"><i class="fab fa-2x fa-facebook-f"></i></a>
                            <a class="text-white mr-4" href="https://www.linkedin.com/company/egestorasistemasesolucoes/" target="_blank"><i class="fab fa-2x fa-linkedin-in"></i></a>
                            <a class="text-white" href="https://www.instagram.com/egestora" target="_blank"><i class="fab fa-2x fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-5">
                        <div class="d-flex flex-column justify-content-start">
                            @* @foreach (var item in primeiraColuna)
                            {
                                <a class="text-white mb-2" href="~/a/@(item.ChaveUrl)#modulos"><i class="fa fa-angle-right mr-2"></i>@(item.Nome)</a>
                            } *@
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-5">
                        <div class="d-flex flex-column justify-content-start">
                            @* @foreach (var item in segundaColuna)
                            {
                                <a class="text-white mb-2" href="~/a/@(item.ChaveUrl)#modulos"><i class="fa fa-angle-right mr-2"></i>@(item.Nome)</a>
                            } *@
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="bg-dark">
            <div class="container text-white">
                <div class="copyright py-3">
                    &copy; <a href="https://www.egestora.com.br" target="_blank" rel="nofollow">@DateTime.Now.Year E-GESTORA </a> - Todos os Direitos Reservados.
                    <div>
                        <div class="poweredby">
                            <span class="title">
                                powered by
                            </span>
                            <a href="https://www.vartechs.com.br">
                                <img src="~/img/poweredby.png" title="VarTechs" alt="VarTechs">
                            </a>
                        </div>

                        <span class="texto-data-publicacao">
                            Última publicação:
                            @appSetting.VersionData (@appSetting.Version)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- Footer End -->
    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary rounded-0 btn-lg-square back-to-top"><i class="fa fa-angle-double-up"></i></a>

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="~/template/online-education-website-template/lib/easing/easing.min.js"></script>
    <script src="~/template/online-education-website-template/lib/waypoints/waypoints.min.js"></script>
    <script src="~/template/online-education-website-template/lib/counterup/counterup.min.js"></script>
    <script src="~/template/online-education-website-template/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/template/online-education-website-template/plugins/select2/js/select2.min.js"></script>
    <script src="~/template/online-education-website-template/plugins/select2/js/i18n/pt-BR.js"></script>
    <script src="~/lib/sweetalert2-11/sweetalert2.all.min.js"></script>

