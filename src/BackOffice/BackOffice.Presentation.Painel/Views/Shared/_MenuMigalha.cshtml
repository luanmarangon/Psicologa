@model List<MenuMigalhaItem>
@inject IAppSettings appSetting


<section class="pt-3 pb-3 pr-3 pl-3 page-info section-padding top-sticky" style="background:#eaf2ff; box-shadow: 0px 2px 0px #ece4e470;">
        <div class=" small">
            <div>
                <a href="~/Home" class="home">Início</a>
                    @foreach (var item in Model)
                    {
                        if(item.URL != "")
                        {
                            <i class="fa fa-angle-double-right pt-1 px-3 "></i><a href="@(appSetting.BaseURL + item.URL)">@item.Nome</a>
                        }
                        else
                        {
                            <i class="fa fa-angle-double-right pt-1 px-3"></i><span class="font-weight-bold cursor-padrao">@item.Nome</span>
                        }
                    }
             </div>
        </div>
    </section>
