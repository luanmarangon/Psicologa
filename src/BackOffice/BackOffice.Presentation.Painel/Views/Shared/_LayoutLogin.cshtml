@inject IAppSettings appSetting
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>Portal E-Academy - E-Gestora</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="Treinamento Capacitação Loja Virtual E-Commerce Delivery Varejo Mercado Sistema Tabela de Preço Super Painel Digital ERP Retaguardar PDV Frente de Caixa" name="keywords">
    <meta content="O Portal oficial de capacitação da E-Gestora Sistemas e Soluções" name="description">
    <link rel="icon" type="image/png" href="~/img/favicon.png">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="~/template/online-education-website-template/css/style.css" rel="stylesheet">
    <link href="~/css/views/login/Index.css?cache=@appSetting.Version" rel="stylesheet" />
    <link href="~/css/loading.css?cache=@appSetting.Version" rel="stylesheet" />
    <script>
        const BASE_URL = "@appSetting.BaseURL";
    </script>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
        }

            body.page-login {
                background: #0b0f1a;
                display: flex;
                align-items: stretch;
                min-height: 100vh;
            }

        /* ===== LAYOUT PRINCIPAL ===== */
        .academy-page-wrap {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* ===== PAINEL ESQUERDO ===== */
        .academy-left {
            flex: 1;
            background: linear-gradient(145deg, #0d1525 0%, #111c33 50%, #0e1e3b 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

            .academy-left::before {
                content: '';
                position: absolute;
                top: -80px;
                left: -80px;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(37,99,235,0.18) 0%, transparent 70%);
                border-radius: 50%;
                pointer-events: none;
            }

            .academy-left::after {
                content: '';
                position: absolute;
                bottom: -60px;
                right: -60px;
                width: 300px;
                height: 300px;
                background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);
                border-radius: 50%;
                pointer-events: none;
            }

        .academy-left-content {
            position: relative;
            z-index: 1;
        }

        .academy-brand-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(37,99,235,0.15);
            border: 1px solid rgba(59,130,246,0.25);
            border-radius: 100px;
            padding: 6px 16px;
            margin-bottom: 2.5rem;
        }

        .academy-badge-dot {
            width: 8px;
            height: 8px;
            background: #3b82f6;
            border-radius: 50%;
            animation: academyPulse 2s infinite;
        }

        @@keyframes academyPulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.85);
            }
        }

        .academy-brand-badge span {
            font-size: 12px;
            color: #93c5fd;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .academy-left h1 {
            font-family: 'Sora', sans-serif;
            font-size: 2.6rem;
            font-weight: 600;
            color: #f0f4ff;
            line-height: 1.2;
            margin-bottom: 1.2rem;
        }

            .academy-left h1 span {
                color: #60a5fa;
            }

        .academy-left-desc {
            font-size: 15px;
            color: #8899b8;
            line-height: 1.75;
            max-width: 360px;
            margin-bottom: 2.5rem;
        }

        .academy-features {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

            .academy-features li {
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 14px;
                color: #a0b4cc;
            }

        .academy-feat-icon {
            width: 34px;
            height: 34px;
            background: rgba(59,130,246,0.12);
            border: 1px solid rgba(59,130,246,0.2);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 15px;
            color: #60a5fa;
        }

        /* ===== PAINEL DIREITO ===== */
        .academy-right {
            width: 480px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            padding: 3rem 3.5rem;
            position: relative;
            overflow-y: auto;
            min-height: 100vh;
        }

        .academy-right-inner {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 2rem 0;
        }

        .academy-right::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 3px;
            height: 100%;
            background: linear-gradient(180deg, transparent 0%, #3b82f6 35%, #1d4ed8 70%, transparent 100%);
        }

        /* Logo */
        .academy-logo-area {
            margin-bottom: 2.5rem;
        }

        .academy-logo-icon {
            width: 54px;
            height: 54px;
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.1rem;
        }

            .academy-logo-icon img {
                max-width: 38px;
                max-height: 38px;
                object-fit: contain;
                filter: brightness(0) invert(1);
            }

            /* Se não houver imagem de logo, exibe ícone padrão */
            .academy-logo-icon .fa-graduation-cap {
                font-size: 22px;
                color: white;
            }

        .academy-login-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .academy-login-subtitle {
            font-size: 14px;
            color: #64748b;
            font-weight: 400;
        }

        /* ===== FORMULÁRIO ===== */
        .academy-form-group {
            margin-bottom: 1.1rem;
        }

        .academy-form-label {
            font-size: 13px;
            font-weight: 500;
            /* color: #374151; */
            color: balck;
            margin-bottom: 6px;
            display: block;
        }

        .academy-input-wrap {
            position: relative;
        }

            .academy-input-wrap .form-control {
                width: 100%;
                height: 46px;
                border: 1.5px solid #e2e8f0;
                border-radius: 10px !important;
                padding: 0 44px 0 14px;
                font-size: 14px;
                font-family: 'DM Sans', sans-serif;
                color: #1e293b;
                background: #f8fafc;
                transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
                outline: none;
                box-shadow: none;
            }

                .academy-input-wrap .form-control:focus {
                    border-color: #3b82f6;
                    background: #ffffff;
                    box-shadow: 0 0 0 3px rgba(59,130,246,0.12) !important;
                }

                .academy-input-wrap .form-control::placeholder {
                    color: #94a3b8;
                }

            .academy-input-wrap .input-group-append {
                position: absolute;
                right: 0;
                top: 0;
                height: 46px;
                display: flex;
                align-items: center;
                padding-right: 14px;
            }

            .academy-input-wrap .input-group-text {
                background: transparent;
                border: none;
                padding: 0;
                color: #94a3b8;
                font-size: 15px;
            }

        /* ===== REMEMBER + BOTÃO ===== */
        .academy-form-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .icheck-primary label {
            font-size: 13px;
            color: #64748b;
            cursor: pointer;
            padding-left: 4px;
        }

        .academy-btn-primary {
            width: 100%;
            height: 48px;
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            color: white;
            border: none !important;
            outline: none !important;
            box-shadow: none !important;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 500;
            font-family: 'Sora', sans-serif;
            cursor: pointer;
            letter-spacing: 0.01em;
            transition: background 0.2s ease, transform 0.15s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
        }

            .academy-btn-primary:hover,
            .academy-btn-primary:focus,
            .academy-btn-primary:active,
            .academy-btn-primary:focus-visible,
            .academy-btn-primary:not(:disabled):not(.disabled):active {
                background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 100%);
                outline: none !important;
                box-shadow: none !important;
                border: none !important;
                color: white;
            }

            .academy-btn-primary:hover {
                transform: translateY(-1px);
            }

            .academy-btn-primary:active {
                transform: translateY(0);
            }

        .academy-btn-secondary {
            background: transparent;
            color: #3b82f6;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            padding: 10px 20px;
            height: 46px;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            transition: all 0.2s;
        }

            .academy-btn-secondary:hover {
                background: #f1f5f9;
                border-color: #c7d2fe;
                color: #1d4ed8;
            }

        .academy-recover-link {
            font-size: 13px;
            color: #3b82f6;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }

            .academy-recover-link:hover {
                color: #1d4ed8;
                text-decoration: underline;
            }

        /* ===== FOOTER ===== */
        .academy-footer {
            margin-top: 2rem;
            text-align: center;
            border-top: 1px solid #e2e8f0;
            padding-top: 1.2rem;
        }

            .academy-footer .version-tag {
                font-size: 11px;
                color: #64748b;
                font-family: monospace;
                letter-spacing: 0.03em;
                display: block;
                margin-bottom: 5px;
            }

            .academy-footer p {
                font-size: 12px;
                color: #475569;
                line-height: 1.6;
            }

            .academy-footer a {
                color: #2563eb;
                text-decoration: none;
                font-weight: 500;
            }

                .academy-footer a:hover {
                    text-decoration: underline;
                }

        /* ===== RESPONSIVO ===== */
        @@media (max-width: 900px) {
            .academy-left {
                display: none;
            }

            .academy-right {
                width: 100%;
                padding: 2.5rem 2rem;
            }
        }

        @@media (max-width: 480px) {
            .academy-right {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body class="page-login">
    <div class="academy-page-wrap">
        <!-- Painel esquerdo decorativo -->
        <div class="academy-left">
            <div class="academy-left-content">
                <div class="academy-brand-badge">
                    <div class="academy-badge-dot"></div>
                    <span>MRG tech</span>
                </div>
                <h1>Portal <span>@appSetting.Nome</span></h1>
                <p class="academy-left-desc">
                    Plataforma de gestão para profissionais de psicologia — prontuários, agendamentos e muito mais.
                </p>
                <ul class="academy-features">
                    <li>
                        <div class="academy-feat-icon"><i class="fas fa-brain"></i></div>
                        Gestão de prontuários e sessões
                    </li>
                    <li>
                        <div class="academy-feat-icon"><i class="fas fa-user-friends"></i></div>
                        Agendamento e controle de pacientes
                    </li>
                    <li>
                        <div class="academy-feat-icon"><i class="fas fa-shield-alt"></i></div>
                        Sigilo e segurança de dados
                    </li>
                </ul>
            </div>
        </div>

        <!-- Painel direito: login/conteúdo -->
        <div class="academy-right">
            <div class="academy-right-inner">
                <div class="academy-logo-area">
                    <div class="academy-logo-icon">
                        <img src="~/img/logo/logo.png" alt="@appSetting.Nome"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='block'">
                        <i class="fas fa-graduation-cap" style="display:none"></i>
                    </div>
                    <div class="academy-login-title">Bem-vindo de volta</div>
                    <div class="academy-login-subtitle">Portal @appSetting.Nome</div>
                </div>

                @RenderBody()
            </div>

            <footer class="academy-footer">
                <span class="version-tag">@appSetting.Version (@appSetting.VersionData)</span>
                @* <p>
                    <a href="http://www.egestora.com.br/" target="_blank">E-Gestora – Sistemas e Soluções</a><br>
                    Todos os direitos reservados
                </p> *@
                <p>© @DateTime.Now.Year @appSetting.Nome — Todos os direitos reservados.</p>
                <p>Desenvolvido por  <a href="#" target="_blank">MRG tech</a><br></p>
            </footer>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2-11/sweetalert2.all.min.js"></script>
    <script src="~/js/site.js?cache=@appSetting.Version"></script>
    <script src="~/js/HTTPClient.js?cache=@appSetting.Version"></script>
    <script src="~/serverapp/views/login/Index.js?cache=@appSetting.Version"></script>
</body>
</html>
